{
	"name": "@pie-players/assessment-demos",
	"version": "0.1.10",
	"description": "Progressive demos for PIE Assessment Player",
	"type": "module",
	"private": true,
	"scripts": {
		"dev": "vite dev",
		"build": "svelte-kit sync && vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@pie-players/pie-assessment-toolkit": "workspace:*",
		"@pie-players/pie-assessment-player": "workspace:*",
		"@pie-players/pie-players-shared": "workspace:*",
		"@pie-players/pie-section-player-tools-event-debugger": "workspace:*",
		"@pie-players/pie-section-player-tools-instrumentation-debugger": "workspace:*",
		"@pie-players/pie-section-player-tools-session-debugger": "workspace:*",
		"@pie-players/pie-section-player-tools-shared": "workspace:*",
		"@pie-players/pie-tool-text-to-speech": "workspace:*",
		"@pie-players/tts-server-google": "workspace:*",
		"@pie-players/tts-server-polly": "workspace:*"
	},
	"devDependencies": {
		"@sveltejs/adapter-node": "5.5.4",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"daisyui": "^5.5.19",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.5",
		"tailwindcss": "^4.2.2",
		"typescript": "^5.9.3",
		"vite": "^8.0.1"
	},
	"license": "MIT"
