{
	"name": "@pie-players/pie-assessment-player",
	"version": "0.3.17",
	"type": "module",
	"description": "Assessment-level coordinator custom elements for orchestrating section-player instances",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/pie-framework/pie-players.git",
		"directory": "packages/assessment-player"
	},
	"publishConfig": {
		"access": "public"
	},
	"unpkg": "./dist/pie-assessment-player.js",
	"jsdelivr": "./dist/pie-assessment-player.js",
	"main": "./dist/pie-assessment-player.js",
	"types": "./dist/pie-assessment-player.d.ts",
	"exports": {
		".": {
			"types": "./dist/pie-assessment-player.d.ts",
			"import": "./dist/pie-assessment-player.js"
		},
		"./components/assessment-player-default-element": {
			"types": "./dist/pie-assessment-player.d.ts",
			"import": "./dist/pie-assessment-player.js"
		},
		"./components/assessment-player-shell-element": {
			"types": "./dist/pie-assessment-player.d.ts",
			"import": "./dist/pie-assessment-player.js"
		},
		"./contracts/public-events": {
			"types": "./dist/pie-assessment-player.d.ts",
			"import": "./dist/pie-assessment-player.js"
		},
		"./contracts/runtime-host-contract": {
			"types": "./dist/pie-assessment-player.d.ts",
			"import": "./dist/pie-assessment-player.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "vite build",
		"dev": "vite build --watch",
		"typecheck": "tsc --noEmit",
		"check": "tsc --noEmit",
		"lint": "biome check ."
	},
	"dependencies": {
		"@pie-players/pie-assessment-toolkit": "workspace:*",
		"@pie-players/pie-players-shared": "workspace:*",
		"@pie-players/pie-section-player": "workspace:*"
	},
	"devDependencies": {
		"@playwright/test": "^1.58.2",
		"@biomejs/biome": "^2.3.13",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vite-plugin-dts": "^4.5.4"
	},
	"homepage": "https://github.com/pie-framework/pie-players/tree/master/packages/assessment-player#readme",
	"bugs": {
		"url": "https://github.com/pie-framework/pie-players/issues"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"sideEffects": true
}
