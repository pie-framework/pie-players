{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"outDir": "dist",
		"rootDir": "src",
		"declaration": true,
		"declarationMap": true,
		"disableSourceOfProjectReferenceRedirect": true,
		"noUnusedLocals": false,
		"noUnusedParameters": false,
		"moduleResolution": "NodeNext",
		"baseUrl": ".",
		"paths": {
			"@pie-players/pie-assessment-toolkit": ["./src/index.ts"],
			"@pie-players/pie-assessment-toolkit/*": ["./src/*"],
			"@pie-players/pie-tool-calculator-desmos": [
				"./src/types/optional-tool-modules.d.ts"
			],
			"@pie-players/pie-tool-text-to-speech": [
				"../tool-text-to-speech/dist/index.d.ts"
			],
			"@pie-players/pie-tool-tts-inline": [
				"./src/types/optional-tool-modules.d.ts"
			]
		}
	},
	"include": [
		"src/**/*.ts",
		"src/**/*.d.ts",
		"src/**/*.svelte"
	],
	"exclude": [
		"dist",
		"node_modules"
	],
	"references": [
		{
			"path": "../pie-context"
		},
		{
			"path": "../calculator"
		},
		{
			"path": "../calculator-desmos"
		},
		{
			"path": "../tts"
		},
		{
			"path": "../tts-client-server"
		},
		{
			"path": "../players-shared"
		}
	]
}
