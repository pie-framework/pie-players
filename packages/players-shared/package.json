{
	"name": "@pie-players/pie-players-shared",
	"version": "0.3.49",
	"type": "module",
	"description": "Shared runtime + UI utilities for PIE players",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/pie-framework/pie-players.git",
		"directory": "packages/players-shared"
	},
	"publishConfig": {
		"access": "public"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"unpkg": "./dist/index.js",
	"jsdelivr": "./dist/index.js",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./loader-config": {
			"types": "./dist/loader-config.d.ts",
			"import": "./dist/loader-config.js"
		},
		"./security": {
			"types": "./dist/security/index.d.ts",
			"import": "./dist/security/index.js"
		},
		"./object": {
			"types": "./dist/object/index.d.ts",
			"import": "./dist/object/index.js"
		},
		"./types": {
			"types": "./dist/types/index.d.ts",
			"import": "./dist/types/index.js"
		},
		"./pie": {
			"types": "./dist/pie/index.d.ts",
			"import": "./dist/pie/index.js"
		},
		"./pie/tag-names": {
			"types": "./dist/pie/tag-names.d.ts",
			"import": "./dist/pie/tag-names.js"
		},
		"./loaders": {
			"types": "./dist/loaders/index.d.ts",
			"import": "./dist/loaders/index.js"
		},
		"./server/npm-registry": {
			"types": "./dist/server/npm-registry.d.ts",
			"import": "./dist/server/npm-registry.js"
		},
		"./i18n": {
			"types": "./dist/i18n/index.d.ts",
			"import": "./dist/i18n/index.js"
		}
	},
	"files": [
		"dist"
	],
	"dependencies": {
		"@pie-lib/math-rendering-module": "5.0.0",
		"dompurify": "^3.4.0",
		"semver": "^7.7.4"
	},
	"scripts": {
		"build": "rm -rf dist tsconfig.tsbuildinfo && tsc -p tsconfig.json",
		"dev": "tsc -p tsconfig.json --watch",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"lint": "biome check .",
		"check": "tsc -p tsconfig.json --noEmit",
		"test": "bun test",
		"check-i18n": "bun run src/i18n/scripts/check-coverage.ts",
		"scan-hardcoded": "bun run src/i18n/scripts/scan-hardcoded.ts"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.12",
		"@happy-dom/global-registrator": "^20.9.0",
		"@types/semver": "^7.7.1",
		"glob": "^13.0.0",
		"svelte": "^5.55.4",
		"typescript": "^5.9.3"
	},
	"homepage": "https://github.com/pie-framework/pie-players/tree/master/packages/players-shared#readme",
	"bugs": {
		"url": "https://github.com/pie-framework/pie-players/issues"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"sideEffects": true
}
