{
	"name": "@pie-players/pie-section-player-tools-shared",
	"version": "0.3.31",
	"type": "module",
	"description": "Shared UI and helpers for PIE section-player debug tools",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/pie-framework/pie-players.git",
		"directory": "packages/section-player-tools-shared"
	},
	"publishConfig": {
		"access": "public"
	},
	"keywords": [
		"pie",
		"section-player",
		"debugger",
		"shared",
		"web-component"
	],
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"svelte": "./index.ts"
		},
		"./PanelWindowControls.svelte": {
			"types": "./dist/PanelWindowControls.svelte.d.ts",
			"svelte": "./PanelWindowControls.svelte"
		},
		"./PanelResizeHandle.svelte": {
			"types": "./dist/PanelResizeHandle.svelte.d.ts",
			"svelte": "./PanelResizeHandle.svelte"
		},
		"./SharedFloatingPanel.svelte": {
			"types": "./dist/SharedFloatingPanel.svelte.d.ts",
			"svelte": "./SharedFloatingPanel.svelte"
		},
		"./SessionDbPanel.svelte": {
			"types": "./dist/SessionDbPanel.svelte.d.ts",
			"svelte": "./SessionDbPanel.svelte"
		},
		"./DebugPanelToggles.svelte": {
			"types": "./dist/DebugPanelToggles.svelte.d.ts",
			"svelte": "./DebugPanelToggles.svelte"
		}
	},
	"files": [
		"dist",
		"*.svelte",
		"*.ts",
		"package.json"
	],
	"license": "MIT",
	"dependencies": {
		"@pie-players/pie-theme": "workspace:*"
	},
	"types": "./dist/index.d.ts",
	"scripts": {
		"build": "vite build",
		"dev": "vite build --watch",
		"typecheck": "tsc --noEmit",
		"lint": "biome check PanelWindowControls.svelte PanelResizeHandle.svelte SharedFloatingPanel.svelte SessionDbPanel.svelte DebugPanelToggles.svelte floating-panel.ts section-controller.ts index.ts vite.config.ts package.json"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.12",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"svelte": "^5.54.0",
		"typescript": "^5.9.3",
		"vite": "^8.0.10",
		"vite-plugin-dts": "^4.5.4"
	},
	"homepage": "https://github.com/pie-framework/pie-players/tree/master/packages/section-player-tools-shared#readme",
	"bugs": {
		"url": "https://github.com/pie-framework/pie-players/issues"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"sideEffects": false
}
