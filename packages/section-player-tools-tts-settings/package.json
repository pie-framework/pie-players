{
	"name": "@pie-players/pie-section-player-tools-tts-settings",
	"version": "0.3.30",
	"type": "module",
	"description": "Reusable TTS settings panel for PIE section-player development tools",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/pie-framework/pie-players.git",
		"directory": "packages/section-player-tools-tts-settings"
	},
	"publishConfig": {
		"access": "public"
	},
	"keywords": [
		"pie",
		"assessment",
		"section-player",
		"tts",
		"debugger",
		"web-component"
	],
	"svelte": "./TtsSettingsPanel.svelte",
	"main": "./dist/section-player-tools-tts-settings.js",
	"module": "./dist/section-player-tools-tts-settings.js",
	"unpkg": "./dist/section-player-tools-tts-settings.js",
	"jsdelivr": "./dist/section-player-tools-tts-settings.js",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/section-player-tools-tts-settings.js",
			"svelte": "./TtsSettingsPanel.svelte"
		}
	},
	"files": [
		"dist",
		"TtsSettingsPanel.svelte",
		"package.json"
	],
	"license": "MIT",
	"dependencies": {
		"@pie-players/pie-assessment-toolkit": "workspace:*",
		"@pie-players/pie-theme": "workspace:*"
	},
	"types": "./dist/index.d.ts",
	"scripts": {
		"build": "vite build",
		"dev": "vite build --watch",
		"typecheck": "tsc --noEmit",
		"lint": "biome check TtsSettingsPanel.svelte index.ts vite.config.ts package.json"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.12",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"svelte": "^5.54.0",
		"typescript": "^5.9.3",
		"vite": "^8.0.10",
		"vite-plugin-dts": "^4.5.4"
	},
	"homepage": "https://github.com/pie-framework/pie-players/tree/master/packages/section-player-tools-tts-settings#readme",
	"bugs": {
		"url": "https://github.com/pie-framework/pie-players/issues"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"sideEffects": true
}
