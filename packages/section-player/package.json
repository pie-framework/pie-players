{
	"name": "@pie-players/pie-section-player",
	"version": "0.3.7",
	"type": "module",
	"description": "Web component for rendering QTI 3.0 assessment sections with passages and items",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/pie-framework/pie-players.git",
		"directory": "packages/section-player"
	},
	"publishConfig": {
		"access": "public"
	},
	"unpkg": "./dist/pie-section-player.js",
	"jsdelivr": "./dist/pie-section-player.js",
	"main": "./dist/pie-section-player.js",
	"types": "./dist/pie-section-player.d.ts",
	"exports": {
		".": {
			"types": "./dist/pie-section-player.d.ts",
			"import": "./dist/pie-section-player.js"
		},
		"./components/section-player-splitpane-element": {
			"types": "./dist/pie-section-player.d.ts",
			"import": "./dist/pie-section-player.js"
		},
		"./components/section-player-vertical-element": {
			"types": "./dist/pie-section-player.d.ts",
			"import": "./dist/pie-section-player.js"
		},
		"./components/section-player-shell-element": {
			"types": "./dist/pie-section-player.d.ts",
			"import": "./dist/pie-section-player.js"
		},
		"./components/section-player-item-card-element": {
			"types": "./dist/pie-section-player.d.ts",
			"import": "./dist/pie-section-player.js"
		},
		"./components/section-player-passage-card-element": {
			"types": "./dist/pie-section-player.d.ts",
			"import": "./dist/pie-section-player.js"
		},
		"./components/section-player-items-pane-element": {
			"types": "./dist/pie-section-player.d.ts",
			"import": "./dist/pie-section-player.js"
		},
		"./components/section-player-passages-pane-element": {
			"types": "./dist/pie-section-player.d.ts",
			"import": "./dist/pie-section-player.js"
		},
		"./components/section-player-kernel-host-element": {
			"types": "./dist/pie-section-player.d.ts",
			"import": "./dist/pie-section-player.js"
		},
		"./contracts/layout-contract": {
			"types": "./dist/pie-section-player.d.ts",
			"import": "./dist/pie-section-player.js"
		},
		"./contracts/public-events": {
			"types": "./dist/pie-section-player.d.ts",
			"import": "./dist/pie-section-player.js"
		},
		"./contracts/runtime-host-contract": {
			"types": "./dist/pie-section-player.d.ts",
			"import": "./dist/pie-section-player.js"
		},
		"./contracts/layout-parity-metadata": {
			"types": "./dist/pie-section-player.d.ts",
			"import": "./dist/pie-section-player.js"
		},
		"./policies": {
			"types": "./dist/pie-section-player.d.ts",
			"import": "./dist/pie-section-player.js"
		},
		"./utils/player-preload": {
			"types": "./dist/utils/player-preload.d.ts",
			"import": "./dist/utils/player-preload.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "vite build",
		"dev": "vite build --watch",
		"typecheck": "tsc --noEmit",
		"check": "svelte-check --tsconfig ./tsconfig.svelte-check.json --compiler-warnings options_missing_custom_element:ignore",
		"lint": "biome check ."
	},
	"peerDependencies": {
		"@pie-players/pie-tool-annotation-toolbar": "workspace:*"
	},
	"peerDependenciesMeta": {
		"@pie-players/pie-tool-annotation-toolbar": {
			"optional": true
		}
	},
	"dependencies": {
		"@pie-players/pie-assessment-toolkit": "workspace:*",
		"@pie-players/pie-item-player": "workspace:*",
		"@pie-players/pie-context": "workspace:*",
		"@pie-players/pie-players-shared": "workspace:*",
		"@pie-players/pie-toolbars": "workspace:*"
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.11.1",
		"@biomejs/biome": "^2.3.13",
		"@playwright/test": "^1.58.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@types/node": "^25.1.0",
		"svelte": "^5.53.7",
		"svelte-check": "^4.4.4",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vite-plugin-dts": "^4.5.4"
	},
	"homepage": "https://github.com/pie-framework/pie-players/tree/master/packages/section-player#readme",
	"bugs": {
		"url": "https://github.com/pie-framework/pie-players/issues"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"sideEffects": true
