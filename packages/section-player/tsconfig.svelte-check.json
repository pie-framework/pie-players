{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"noUnusedLocals": false,
		"noUnusedParameters": false,
		"checkJs": false,
		"moduleResolution": "NodeNext",
		"rootDir": "..",
		"baseUrl": ".",
		"paths": {
			"@pie-players/pie-players-shared/loaders": [
				"../players-shared/dist/loaders/index.d.ts"
			],
			"@pie-players/pie-players-shared/types": [
				"../players-shared/dist/types/index.d.ts"
			],
			"@pie-players/pie-players-shared/ui/use-promise": [
				"../players-shared/src/ui/use-promise.svelte.ts"
			]
		}
	},
	"include": ["src/**/*.ts", "src/**/*.d.ts", "src/**/*.svelte"],
	"exclude": ["node_modules", "dist"]
}
