	"devDependencies": {
		"@biomejs/biome": "^2.3.10",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"svelte": "^5.54.0",
		"typescript": "^5.9.3",
		"vite": "^8.0.1",
		"vite-plugin-dts": "^4.5.4"
	},
	"homepage": "https://github.com/pie-framework/pie-players/tree/master/packages/tool-annotation-toolbar#readme",
	"bugs": {
		"url": "https://github.com/pie-framework/pie-players/issues"
	},
	"engines": {
