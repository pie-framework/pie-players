{
	"name": "@pie-players/pie-tool-calculator-desmos",
	"version": "0.3.11",
	"type": "module",
	"description": "Calculator tool for PIE assessment player",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/pie-framework/pie-players.git",
		"directory": "packages/tool-calculator-desmos"
	},
	"publishConfig": {
		"access": "public"
	},
	"keywords": [
		"pie",
		"assessment",
		"tool",
		"calculator"
	],
	"main": "./dist/pie-tool-calculator.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/pie-tool-calculator.js"
		}
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"build": "vite build",
		"dev": "vite build --watch",
		"typecheck": "tsc --noEmit",
		"lint": "biome check ."
	},
	"license": "MIT",
	"unpkg": "./dist/pie-tool-calculator.js",
	"jsdelivr": "./dist/pie-tool-calculator.js",
	"dependencies": {
		"@pie-players/pie-assessment-toolkit": "workspace:*",
		"@pie-players/pie-context": "workspace:*",
		"@pie-players/pie-players-shared": "workspace:*"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.10",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"svelte": "^5.53.7",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vite-plugin-dts": "^4.5.4"
	},
	"homepage": "https://github.com/pie-framework/pie-players/tree/master/packages/tool-calculator-desmos#readme",
	"bugs": {
		"url": "https://github.com/pie-framework/pie-players/issues"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"sideEffects": true
}
