{
	"name": "@pie-players/pie-tool-theme",
	"version": "0.3.22",
	"type": "module",
	"description": "Theme tool for PIE assessment player - provides accessible themes and color schemes",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/pie-framework/pie-players.git",
		"directory": "packages/tool-color-scheme"
	},
	"publishConfig": {
		"access": "public"
	},
	"keywords": [
		"pie",
		"assessment",
		"tool",
		"theme",
		"color-scheme",
		"accessibility",
		"wcag",
		"learnosity"
	],
	"svelte": "./tool-color-scheme.svelte",
	"main": "./dist/tool-color-scheme.js",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/tool-color-scheme.js",
			"svelte": "./tool-color-scheme.svelte"
		}
	},
	"files": [
		"dist",
		"tool-color-scheme.svelte",
		"index.ts",
		"package.json"
	],
	"license": "MIT",
	"unpkg": "./dist/tool-color-scheme.js",
	"jsdelivr": "./dist/tool-color-scheme.js",
	"dependencies": {
		"@pie-players/pie-assessment-toolkit": "workspace:*",
		"@pie-players/pie-context": "workspace:*",
		"@pie-players/pie-players-shared": "workspace:*",
		"@pie-players/pie-theme": "workspace:*"
	},
	"types": "./dist/index.d.ts",
	"scripts": {
		"build": "vite build",
		"dev": "vite build --watch",
		"typecheck": "tsc --noEmit",
		"lint": "biome check ."
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.10",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"svelte": "^5.54.0",
		"typescript": "^5.9.3",
		"vite": "^8.0.1",
		"vite-plugin-dts": "^4.5.4"
	},
	"homepage": "https://github.com/pie-framework/pie-players/tree/master/packages/tool-color-scheme#readme",
	"bugs": {
		"url": "https://github.com/pie-framework/pie-players/issues"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"sideEffects": true
}
