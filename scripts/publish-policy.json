{
	"requiredPublishConfigAccess": "public",
	"requiredFields": ["license", "homepage", "bugs", "files", "sideEffects"],
	"requireRepositoryDirectory": true,
	"requireExportsOrMainTypes": true,
	"requireNodeEngine": true,
	"defaultNodeEngine": ">=20.0.0",
	"workspaceRoots": ["packages"],
	"forbiddenPublicExports": {
		"@pie-players/pie-players-shared": [
			"./components",
			"./components/*",
			"./i18n/use-i18n",
			"./i18n/use-i18n-standalone",
			"./ui/use-promise"
		]
	},
	"allowedUndeclaredRuntimeImports": {
		"@pie-players/pie-assessment-toolkit": [
			"@pie-players/pie-tool-calculator-desmos",
			"@pie-players/pie-tool-text-to-speech",
			"@pie-players/pie-tool-tts-inline"
		]
	}
}
