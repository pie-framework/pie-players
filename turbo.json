{
	"$schema": "https://turbo.build/schema.json",
	"globalDependencies": [
		"package.json",
		"bun.lock",
		"turbo.json",
		"tsconfig.json",
		"tsconfig.base.json"
	],
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**", "build/**", ".svelte-kit/**"],
			"inputs": [
				"$TURBO_DEFAULT$",
				"$TURBO_ROOT$/tsconfig.json",
				"$TURBO_ROOT$/tsconfig.base.json"
			]
		},
		"test": {
			"dependsOn": ["build"],
			"cache": false
		},
		"lint": {
			"cache": false
		},
		"typecheck": {
			"cache": false
		},
		"check": {
			"cache": false
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"clean": {
			"cache": false
		}
	}
}
